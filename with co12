import streamlit as st
import google.generativeai as genai
from ultralytics import YOLO
from PIL import Image
import numpy as np

# 1. 基本配置
st.set_page_config(page_title="AI 視覺分析", layout="wide")
st.title("🔬 YOLO + Gemini 雙腦實驗室")

# 2. 安全讀取 Secrets
if "GEMINI_API_KEY" not in st.secrets:
    st.error("❌ 錯誤：請在 Streamlit Secrets 設定 GEMINI_API_KEY")
    st.stop()

genai.configure(api_key=st.secrets["GEMINI_API_KEY"])
model_gemini = genai.GenerativeModel('gemini-1.5-flash-latest')

@st.cache_resource
def load_yolo():
    return YOLO('yolov8n.pt')

yolo = load_yolo()

# 3. 檔案上傳
img_file = st.file_uploader("📤 上傳一張照片", type=['jpg', 'png', 'jpeg'])

if img_file:
    # 讀取圖片
    img = Image.open(img_file)
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.subheader("🤖 YOLO 偵測")
        results = yolo(img, conf=0.25)
        res_img = results[0].plot()
        st.image(res_img, use_container_width=True)
        
        labels = [results[0].names[int(c)] for c in results[0].boxes.cls]
        st.write(f"初步偵測結果: {', '.join(labels) if labels else '未發現物體'}")

    with col2:
        st.subheader("🧠 Gemini 深度分析")
        if st.button("🪄 啟動 AI 推論"):
            with st.spinner('AI 正在看圖說故事...'):
                try:
                    prompt = "請分析圖片中的物體，給出科學名稱與一則冷知識。用繁體中文回答。"
                    response = model_gemini.generate_content([prompt, img])
                    st.write(response.text)
                except Exception as e:
                    st.error(f"API 呼叫失敗: {e}")
